# --- NextAuth ---
# Run `openssl rand -base64 32` to generate NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Google OAuth (AG Barr calendar) ---
# https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft / Azure AD OAuth (EFPT Outlook calendar) ---
# https://portal.azure.com → App registrations
# Redirect URI (type: Web): ${NEXTAUTH_URL}/api/auth/callback/azure-ad
# Use "common" for multi-tenant or a specific tenant GUID for single-tenant.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
